#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONDUCTOR_DIR="$REPO_ROOT/mcp/conductor"

if [[ ! -d "$CONDUCTOR_DIR" ]]; then
  echo "error: missing $CONDUCTOR_DIR" >&2
  exit 2
fi

if [[ ! -d "$CONDUCTOR_DIR/node_modules" ]]; then
  (cd "$CONDUCTOR_DIR" && npm ci)
fi

if [[ ! -f "$CONDUCTOR_DIR/dist/autopilot-flow-cli.js" ]]; then
  (cd "$CONDUCTOR_DIR" && npm run build)
fi

node "$CONDUCTOR_DIR/dist/autopilot-flow-cli.js" --repo-root "$REPO_ROOT" "$@"
