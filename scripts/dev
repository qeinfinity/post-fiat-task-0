#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MANIFEST_PATH="${MANIFEST_PATH:-$REPO_ROOT/.autopilot/manifest.json}"
CONDUCTOR_DIR="$REPO_ROOT/mcp/conductor"
SECURITY_CLI="$CONDUCTOR_DIR/dist/security-cli.js"

if [[ ! -f "$MANIFEST_PATH" ]]; then
  echo "error: missing manifest at $MANIFEST_PATH" >&2
  echo "hint: run 'bash scripts/autopilot' to generate a project + manifest first" >&2
  exit 2
fi

if [[ ! -d "$CONDUCTOR_DIR/node_modules" ]]; then
  (cd "$CONDUCTOR_DIR" && npm ci)
fi

if [[ ! -f "$SECURITY_CLI" ]]; then
  (cd "$CONDUCTOR_DIR" && npm run build)
fi

node "$SECURITY_CLI" run-start \
  --repo-root "$REPO_ROOT" \
  --manifest "$MANIFEST_PATH"
