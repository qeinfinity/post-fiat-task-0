{
  "profileVersion": 1,
  "defaultProfile": "codex-standard",
  "profiles": {
    "codex-standard": {
      "kind": "codex",
      "command": "codex",
      "tabPrefix": "[Codex]",
      "allowFullAuto": false,
      "defaultFullAuto": false,
      "defaultSandbox": "workspace-write",
      "allowedFlags": ["-m", "--sandbox"],
      "allowedSandboxes": ["read-only", "workspace-write"],
      "idlePattern": "\\?\\s+for shortcuts\\s+\\d+%\\s+context left"
    },
    "codex-full-auto": {
      "kind": "codex",
      "command": "codex",
      "tabPrefix": "[Codex]",
      "allowFullAuto": true,
      "defaultFullAuto": true,
      "defaultSandbox": "workspace-write",
      "allowedFlags": ["-m", "--sandbox", "--full-auto"],
      "allowedSandboxes": ["workspace-write"],
      "idlePattern": "\\?\\s+for shortcuts\\s+\\d+%\\s+context left"
    },
    "generic-local": {
      "kind": "generic",
      "command": "agent",
      "tabPrefix": "[Agent]",
      "baseArgs": [],
      "promptPlacement": "positional",
      "cwdFlag": null,
      "allowFullAuto": false,
      "defaultFullAuto": false,
      "allowedFlags": []
    }
  }
}
